{
  "name": "@landmatch/server",
  "version": "1.0.0",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:debugging": "SENTRY_SPOTLIGHT=1 pnpm dev",
    "build": "tsc",
    "lint": "tsc --noEmit && eslint src/",
    "start": "node dist/index.js",
    "test": "vitest --passWithNoTests",
    "test:run": "vitest run --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "backfill:homestead": "tsx scripts/backfill-homestead-score.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@hono/node-server": "^1.11.0",
    "@landmatch/api": "workspace:*",
    "@landmatch/db": "workspace:*",
    "@landmatch/enrichment": "workspace:*",
    "@landmatch/scoring": "workspace:*",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "@sentry/node": "^10.63.0",
    "argon2": "^0.44.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.4.7",
    "hono-rate-limiter": "^0.5.3",
    "jose": "^6.1.3",
    "node-cron": "^4.2.1",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "resend": "^4.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^4.0.18",
    "pino-pretty": "^13.1.3",
    "vitest": "^4.0.16"
  }
}
